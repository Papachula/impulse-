IRF_PERIODS = 12        # horizon to plot
SIGNIF = 0.05           # 95% CI
MAX_LAGS = 4           # max lags to test when selecting VAR order



def load_series(cfg):
    path = cfg["file"]

    if str(path).lower().endswith(".csv"):
        df = pd.read_csv(path)
    else:
        df = pd.read_excel(path)

    df.columns = df.columns.str.strip()

    for col in (cfg["date_col"], cfg["value_col"]):
        if col not in df.columns:
            raise KeyError(
                f"Column '{col}' not found in {path}. "
                f"Actual columns are: {list(df.columns)}"
            )

    df[cfg["date_col"]] = pd.to_datetime(df[cfg["date_col"]], errors="coerce")
    df[cfg["value_col"]] = pd.to_numeric(df[cfg["value_col"]], errors="coerce")

    df = df.dropna(subset=[cfg["date_col"], cfg["value_col"]])

    df = df.set_index(cfg["date_col"]).sort_index()
    s = df[cfg["value_col"]].rename(cfg["name"])


#resample to last day of month for me snapshot to evoid spurious 30 identical day rows
    if cfg.get("resample"):
        s = s.resample(cfg["resample"]).last()

    return s


def build_dataset(series_cfg):
    series_list = [load_series(cfg) for cfg in series_cfg]
    df = pd.concat(series_list, axis=1).dropna()
    return df



#log diff
def apply_transform(s, transform, scale=1.0):
    s = s * scale
    if transform == "log_diff":
        s = np.log(s)
        s = s.replace([np.inf, -np.inf], np.nan)
        s = s.diff()
    elif transform == "diff":
        s = s.diff()
    elif transform == "none":
        pass
    else: 
        raise ValueError(f"unknown transform '{transform}'")
    
    return s

def transform_tier1(df, series_cfg):
    out = pd.DataFrame(index=df.index)
    for cfg in series_cfg:
        name=cfg['name']
        transform = cfg.get("transform", "diff")
        scale = cfg.get("scale", 1.0)
        out[name] = apply_transform(df[name], transform, scale)

    return out.dropna()



def fit_var(df, max_lags=MAX_LAGS):
    model = VAR(df)
    lag_selection = model.select_order(maxlags=max_lags)
    chosen_lag = lag_selection.aic
    print("\nLag order selection (AIC):")
    print(lag_selection.summary())
    print(f"\nSelected lag order (AIC): {chosen_lag}")

    results = model.fit(chosen_lag if chosen_lag > 0 else 1)
    print(results.summary())
    return results




def plot_irf_grid(results, var_names, periods=IRF_PERIODS, signif=SIGNIF):
    irf = results.irf(periods=periods)

    orth_irfs = irf.orth_irfs           # shape (periods+1, k, k)
    stderr = irf.stderr(orth=True)      # shape (periods+1, k, k)

    z = 1.96 if signif == 0.05 else abs(np.round(1 - signif, 2))
    horizons = np.arange(orth_irfs.shape[0])
    k = len(var_names)

    fig, axes = plt.subplots(k, k, figsize=(2.6 * k, 2.2 * k), squeeze=False)
    fig.suptitle(
        "Impulse Response\nResponse to Cholesky One S.D."
        f"Innovations\n{int((1-signif)*100)}% CI",
        fontsize=12, y=1.02
    )



    for i, response_var in enumerate(var_names):        # rows = response
        for j, impulse_var in enumerate(var_names):      # cols = impulse
            ax = axes[i, j]
            resp = orth_irfs[:, i, j]
            se = stderr[:, i, j]
            upper = resp + z * se
            lower = resp - z * se

            ax.plot(horizons, resp, color="black", linewidth=1.3)
            ax.fill_between(horizons, lower, upper, color="gray", alpha=0.3)
            ax.axhline(0, color="black", linewidth=0.6, linestyle="--")
            ax.set_title(f"Response of {response_var} to {impulse_var} Innovation",
                          fontsize=10, style="italic")
            ax.set_xlim(0, periods)
            ax.grid(alpha=0.2)

    plt.tight_layout()
    plt.show()

    return orth_irfs, stderr, horizons



def plot_irf_column (results, var_names, shock_var, periods=IRF_PERIODS, signif=SIGNIF):
    irf = results.irf(periods=periods)
    orth_irfs = irf.orth_irfs
    stderr = irf.stderr(orth =True)
    z = 1.96
    j = var_names.index(shock_var)
    k = len(var_names)

    fig, axes = plt.subplots(k, 1, figsize=(6, 2.5*k), squeeze = False)
    fig.suptitle(f"Response of All Variables to a {shock_var} Innovation", fontsize=12)

    for i, response_var in enumerate(var_names):
        ax = axes[i, 0]
        resp = orth_irfs[:, i, j]
        se = stderr[:, i, j]
        ax.plot(resp, color = "black")
        ax.fill_between(range(len(resp)), resp -z*se, resp +z*se, color="gray", alpha = 0.3)
        ax.axhline(0, linestyle="--", color = "red", linewidth=0.6)
        ax.set_title(response_var, fontsize=8)

    plt.tight_layout
    plt.show()






