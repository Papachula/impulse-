            tr = (cfg["target_transform"] if c == tcol
                  else cfg["predictors"][c]["transform"])
            deltas.append(0.0 if is_growth_like(tr) else 0.9)
        delta = np.array(deltas)
    else:
        delta = np.array([cfg["prior_mean_delta"][c] for c in Yq.columns])
    print(f"    prior own-lag means delta: "
          f"{dict(zip(Yq.columns, delta.round(2)))}")

    print("\n[2] Hyperparameter selection (marginal likelihood, GLP 2015)")
    E = exog_df.values if exog_df is not None else None
    hyper = select_hyperparams(Yq.values, E, cfg, delta)

    print("\n[3] Recursive out-of-sample backtest "
          f"(origins from {cfg['oos_start']})")
    bt = run_backtest(Yq, exog_df, cfg, delta, hyper, rng)
    summ = backtest_summary(bt, cfg)
    print(summ)
    bt.to_csv(os.path.join(cfg["output_dir"], "backtest.csv"), index=False)
    plot_oos(bt, cfg, os.path.join(cfg["output_dir"], "oos_forecasts.png"))

    print(f"\n[4] Full-sample fit + {cfg['horizon']}-quarter density forecast "
          f"({cfg['n_draws']} draws)")
    lam, mu, tau = hyper
    m = MinnesotaBVAR(cfg["n_lags"], lam, cfg["lag_decay"], mu, tau,
                      delta).fit(Yq.values, E)
    p = cfg["n_lags"]
    rows = [f"{v}.L{1}" for l in range (1, p + 1) for v in Yq.columns]
    rows += ["const"]+ (list(exog_df.columns) if  exog_df is not None else [])
    print("---"*50)
    print(f"\n{tcol} equation coefficients (posterior mean):")
    print(pd.Series(m.B_post[:, list(Yq.columns).index(tcol)], index=rows).round(3).to_string())
    print("---"*50)
    draws = m.sample_forecasts(Yq.values, E, cfg["horizon"],
                               cfg["n_draws"], rng)
    j = list(Yq.columns).index(tcol)
    fdates = pd.period_range(Yq.index[-1], periods=cfg["horizon"] + 1,
                             freq="Q")[1:]
    fc = pd.DataFrame({
        "quarter": fdates.astype(str),
        "median": np.median(draws[:, :, j], axis=0),
        "mean": draws[:, :, j].mean(axis=0),
        "lo68": np.quantile(draws[:, :, j], 0.16, axis=0),
        "hi68": np.quantile(draws[:, :, j], 0.84, axis=0),
        "lo90": np.quantile(draws[:, :, j], 0.05, axis=0),
        "hi90": np.quantile(draws[:, :, j], 0.95, axis=0),
        "prob_negative": (draws[:, :, j] < 0).mean(axis=0),
    })
    print(fc.round(2).to_string(index=False))
    fc.to_csv(os.path.join(cfg["output_dir"], "forecast.csv"), index=False)
    plot_fan(Yq, draws, cfg, os.path.join(cfg["output_dir"], "fan_chart.png"))

    raw = pd.read_excel(cfg["excel_path"], sheet_name = cfg["sheet_name"])
    raw[cfg["date_col"]] = pd.to_datetime(raw[cfg["date_col"]])
    raw = raw.set_index(cfg["date_col"]).sort_index()
    raw = raw[raw.index<= pd.Timestamp("2026-06-30")]
    obs = {}
    for c, spec in cfg["predictors"].items():
         q = transform(_q_resample(raw[c].ffill(), spec.get("agg")),
                  spec["transform"])
    assert str(q.index[-1].date()) == "2026-06-30", f"{c} stops early"
    obs[c] = float(q.iloc[-1])
    print("\nQ2 predictor obersvations:",
      {k: round(v,3) for k, v in obs.items()})
    d = nowcast_q(m, Yq, obs, 6000, rng,
              exog_now=np.zeros(m.n_exog) if m.n_exog else None)
    print(
        f"Q2 2026 GDP nowcast: mean {d.mean():.2f}, "
     f"median {np.median(d):.2f}")

    print(f" 68% [{np.quantile(d, 0.16):.2f}, {np.quantile(d, 0.84):.2f}]"
      f"90%[{np.quantile(d, 0.05):.2f}, {np.quantile(d,0.95):.2f}]"
      f"p(neg) {np.mean(d<0):.0%}")



    with open(os.path.join(cfg["output_dir"], "summary.txt"), "w") as f:
        f.write("BVAR GDP forecast summary\n" + "=" * 40 + "\n")
        f.write(f"sample: {Yq.index[0].date()} - {Yq.index[-1].date()} "
                f"({len(Yq)} quarters)\n")
        f.write(f"vars: {list(Yq.columns)}\nlags: {cfg['n_lags']}\n")
        f.write(f"hyperparams: lambda={lam}, soc={mu}, dio={tau}\n\n")
        f.write("Out-of-sample:\n" + summ + "\n\nForecast:\n")
        f.write(fc.round(3).to_string(index=False) + "\n")
    print(f"\nOutputs -> {os.path.abspath(cfg['output_dir'])}/")
    return bt, fc



def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--selftest", action="store_true")
    ap.add_argument("--excel", default=None)
    args = ap.parse_args()

    cfg = dict(CONFIG)
    if args.excel:
        cfg["excel_path"] = args.excel

    if args.selftest:
        print(">> SELF-TEST: synthetic daily dragged panel; PAYROLLS/CAPGOODS "
              "lead GDP by one quarter; NOISE is useless.\n")
        panel = make_synthetic_daily()
        path = "/tmp/bvar_selftest.xlsx"
        panel.to_excel(path, index=False)
        cfg.update({
            "excel_path": path,
            "output_dir": "bvar_output_selftest",
            "predictors": {
                "PAYROLLS": {"transform": "ann_log_growth", "agg": "last"},
                "CAPGOODS": {"transform": "ann_log_growth", "agg": "last"},
                "NOISE":    {"transform": "diff",           "agg": "last"},
            },
            "target_release_shift_q": 1,
            "oos_start": "2013-01-01",
        })
    elif not os.path.exists(cfg["excel_path"]):
        sys.exit(f"Excel not found: {cfg['excel_path']} "
                 "(edit CONFIG, pass --excel, or run --selftest)")

    run(cfg)


if __name__ == "__main__":
    main()
