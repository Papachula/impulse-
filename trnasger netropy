TRANSFORMS = ("level", "diff", "log_diff", "pct_change", "yoy_log_diff", "yoy_pct")


def load_excel(cfg) -> pd.DataFrame:
    df = pd.read_excel(cfg["excel_path"], sheet_name=cfg["sheet_name"])
    for col in (cfg["date_col"], cfg["source_col"], cfg["target_col"]):
        if col not in df.columns:
            raise KeyError(
                f"Column '{col}' not found. Available: {list(df.columns)}"
            )
    df[cfg["date_col"]] = pd.to_datetime(df[cfg["date_col"]])
    df = (
        df[[cfg["date_col"], cfg["source_col"], cfg["target_col"]]]
        .dropna()
        .sort_values(cfg["date_col"])
        .set_index(cfg["date_col"])
    )
    df = df.apply(pd.to_numeric, errors="coerce").dropna()
    if cfg.get("resample"):
        df = df.resample(cfg["resample"]).last().dropna()
    return df


def transform_series(s: pd.Series, method: str, obs_per_year: int = 12) -> pd.Series:
    m = method.lower()
    if m == "level":
        out = s.copy()
    elif m == "diff":
        out = s.diff()
    elif m == "log_diff":
        if (s <= 0).any():
            raise ValueError(
                f"'{s.name}': log_diff requires strictly positive values. "
                "Use 'diff' or 'pct_change' instead."
            )
        out = np.log(s).diff()
    elif m == "pct_change":
        out = s.pct_change()
    elif m == "yoy_log_diff":
        out = np.log(s).diff(obs_per_year)
    elif m == "yoy_pct":
        out = s.pct_change(obs_per_year)
    else:
        raise ValueError(f"Unknown transform '{method}'. Options: {TRANSFORMS}")
    return out.dropna()


def stationarity_report(s: pd.Series, name: str) -> dict:
    """ADF (H0: unit root) + KPSS (H0: stationary)."""
    from statsmodels.tsa.stattools import adfuller, kpss

    adf_stat, adf_p, *_ = adfuller(s.values, autolag="AIC")
    try:
        kpss_stat, kpss_p, *_ = kpss(s.values, regression="c", nlags="auto")
    except Exception:
        kpss_stat, kpss_p = np.nan, np.nan
    verdict = (
        "stationary" if (adf_p < 0.05 and (np.isnan(kpss_p) or kpss_p > 0.05))
        else "CHECK -- possibly non-stationary"
    )
    return {
        "series": name, "n": len(s),
        "ADF stat": adf_stat, "ADF p": adf_p,
        "KPSS stat": kpss_stat, "KPSS p": kpss_p,
        "verdict": verdict,
    }


# ------------------------------------------------------------------------------
# Core estimators
# ------------------------------------------------------------------------------
def _embed(y: np.ndarray, x: np.ndarray, lag: int, k: int):
    """
    Build (target-future, target-past, source-past) matrices for
    TE_{X->Y}(lag) = I( y_t ; x_{t-lag} | y_{t-1},...,y_{t-k} ).
    """
    n = len(y)
    start = max(k, lag)
    idx = np.arange(start, n)
    y_f = y[idx].reshape(-1, 1)                                   # y_t
    y_p = np.column_stack([y[idx - j] for j in range(1, k + 1)])  # y_{t-1..t-k}
    x_p = x[idx - lag].reshape(-1, 1)                             # x_{t-lag}
    return y_f, y_p, x_p


def ksg_cmi(a: np.ndarray, b: np.ndarray, c: np.ndarray,
            knn: int = 4, rng: np.random.Generator | None = None) -> float:
    """
    Conditional mutual information I(A;B|C) in bits.
    Frenzel & Pompe (2007) kNN estimator (KSG algorithm 1 style),
    Chebyshev (max-norm) metric. Tiny jitter breaks ties (standard practice).
    """
    if rng is None:
        rng = np.random.default_rng(0)
    pts = [np.asarray(v, dtype=float) for v in (a, b, c)]
    pts = [v + 1e-10 * np.std(v, axis=0, keepdims=True) * rng.standard_normal(v.shape)
           for v in pts]
    a, b, c = pts
    abc = np.hstack([a, b, c])
    ac = np.hstack([a, c])
    bc = np.hstack([b, c])

    n = abc.shape[0]
    tree_abc = cKDTree(abc)
    # distance to k-th neighbour in the full joint space (exclude self)
    dists, _ = tree_abc.query(abc, k=knn + 1, p=np.inf)
    eps = dists[:, -1]

    def count_lt(space, eps_):
        tree = cKDTree(space)
        # strictly-less-than counts (KSG convention): shrink radius slightly
        r = np.nextafter(eps_, 0)
        return np.array(tree.query_ball_point(space, r, p=np.inf,
                                              return_length=True)) - 1

    n_ac = count_lt(ac, eps)
    n_bc = count_lt(bc, eps)
    n_c = count_lt(c, eps)

    cmi_nats = (digamma(knn)
                + np.mean(digamma(n_c + 1) - digamma(n_ac + 1) - digamma(n_bc + 1)))
    return max(cmi_nats / np.log(2), 0.0)  # nats -> bits, clip tiny negatives


def _quantile_discretize(v: np.ndarray, n_bins: int) -> np.ndarray:
    """Equiprobable (quantile) binning per column -> integer symbols."""
    v = np.asarray(v, dtype=float)
    out = np.empty(v.shape, dtype=np.int64)
    for j in range(v.shape[1]):
        ranks = pd.Series(v[:, j]).rank(method="first").values
        out[:, j] = np.minimum((ranks - 1) * n_bins // len(ranks), n_bins - 1)
    return out


def binned_cmi(a, b, c, n_bins: int = 6) -> float:
    """Plug-in conditional MI in bits on quantile-binned data:
       I(A;B|C) = H(A,C) + H(B,C) - H(C) - H(A,B,C)."""
    A = _quantile_discretize(a, n_bins)
    B = _quantile_discretize(b, n_bins)
    C = _quantile_discretize(c, n_bins)

    def H(*cols):
        arr = np.hstack(cols)
        _, counts = np.unique(arr, axis=0, return_counts=True)
        p = counts / counts.sum()
        return -(p * np.log2(p)).sum()

    val = H(A, C) + H(B, C) - H(C) - H(A, B, C)
    return max(val, 0.0)


def transfer_entropy(x: np.ndarray, y: np.ndarray, lag: int, cfg,
                     rng: np.random.Generator | None = None) -> float:
    """TE_{X->Y} at a given lag, in bits."""
    y_f, y_p, x_p = _embed(y, x, lag, cfg["k_history"])
    if cfg["estimator"] == "ksg":
        return ksg_cmi(y_f, x_p, y_p, knn=cfg["knn"], rng=rng)
    return binned_cmi(y_f, x_p, y_p, n_bins=cfg["n_bins"])


# ------------------------------------------------------------------------------
# Surrogates, ETE, significance
# ------------------------------------------------------------------------------
def block_shuffle(x: np.ndarray, block_len: int, rng: np.random.Generator):
    """Shuffle whole blocks of the source series: preserves within-block
    autocorrelation while destroying the cross-series coupling."""
    n = len(x)
    nb = int(np.ceil(n / block_len))
    pad = nb * block_len - n
    xp = np.concatenate([x, x[:pad]]) if pad else x.copy()
    blocks = xp.reshape(nb, block_len)
    perm = rng.permutation(nb)
    return blocks[perm].reshape(-1)[:n]


def te_with_inference(x, y, lag, cfg, n_surr, rng) -> dict:
    """TE, effective TE (bias-corrected), one-sided p-value, and the
    (1-alpha) surrogate quantile threshold."""
    te = transfer_entropy(x, y, lag, cfg, rng)
    n = len(x)
    bl = cfg["block_length"] or max(2, int(np.ceil(n ** (1 / 3))))
    surr = np.empty(n_surr)
    for i in range(n_surr):
        xs = (block_shuffle(x, bl, rng) if cfg["surrogate_method"] == "block"
              else rng.permutation(x))
        surr[i] = transfer_entropy(xs, y, lag, cfg, rng)
    p = (1 + np.sum(surr >= te)) / (1 + n_surr)          # Davison & Hinkley
    return {
        "te": te,
        "ete": te - surr.mean(),                          # Marschinski & Matassini
        "p": p,
        "threshold": np.quantile(surr, 1 - cfg["alpha"]),
        "surr_mean": surr.mean(),
    }


# ------------------------------------------------------------------------------
# Analysis stages
# ------------------------------------------------------------------------------
def lag_scan(x, y, cfg, rng, label) -> pd.DataFrame:
    rows = []
    for lag in range(1, cfg["max_lag"] + 1):
        r = te_with_inference(x, y, lag, cfg, cfg["n_surrogates"], rng)
        rows.append({"lag": lag, **r})
        print(f"    {label}  lag={lag:>2}  TE={r['te']:.5f}  "
              f"ETE={r['ete']:+.5f}  p={r['p']:.4f}"
              f"{'  *' if r['p'] < cfg['alpha'] else ''}")
    return pd.DataFrame(rows)


def pick_optimal_lag(scan: pd.DataFrame, alpha: float) -> tuple[int, bool]:
    sig = scan[scan["p"] < alpha]
    if len(sig):
        return int(sig.loc[sig["ete"].idxmax(), "lag"]), True
    return int(scan.loc[scan["ete"].idxmax(), "lag"]), False


def rolling_te(x: pd.Series, y: pd.Series, lag: int, cfg, rng, label) -> pd.DataFrame:
    w = cfg["rolling_years"] * cfg["obs_per_year"]
    step = cfg["rolling_step"]
    xv, yv = x.values, y.values
    n = len(xv)
    if n < w + lag + cfg["k_history"] + 10:
        raise ValueError(
            f"Not enough observations ({n}) for a "
            f"{cfg['rolling_years']}-year ({w}-obs) rolling window."
        )
    rows = []
    ends = range(w, n + 1, step)
    for j, end in enumerate(ends):
        xs, ys = xv[end - w:end], yv[end - w:end]
        r = te_with_inference(xs, ys, lag, cfg, cfg["rolling_surrogates"], rng)
        rows.append({"date": y.index[end - 1], **r})
        if (j + 1) % 50 == 0:
            print(f"    {label}: window {j + 1}/{len(list(ends))}")
    return pd.DataFrame(rows).set_index("date")


