def plot_lag_scan(scan_xy, scan_yx, sname, tname, cfg, path):
    fig, axes = plt.subplots(1, 2, figsize=(11, 4), sharey=True)
    for ax, scan, title in (
        (axes[0], scan_xy, f"{sname} → {tname}"),
        (axes[1], scan_yx, f"{tname} → {sname}"),
    ):
        colors = ["#c0392b" if p < cfg["alpha"] else "#95a5a6" for p in scan["p"]]
        ax.bar(scan["lag"], scan["ete"], color=colors, width=0.7,
               label="Effective TE (bias-corrected)")
        ax.plot(scan["lag"], scan["threshold"] - scan["surr_mean"], "k--", lw=1,
                label=f"{int((1-cfg['alpha'])*100)}% surrogate threshold (centred)")
        ax.axhline(0, color="k", lw=0.8)
        ax.set_title(title)
        ax.set_xlabel("lag (periods)")
    axes[0].set_ylabel("Effective transfer entropy (bits)")
    axes[0].legend(fontsize=8, loc="upper right")
    fig.suptitle("Lag scan — red bars significant at "
                 f"α={cfg['alpha']} (block-shuffle surrogates)", y=1.02)
    fig.tight_layout()
    fig.savefig(path, bbox_inches="tight")
    plt.close(fig)


def plot_rolling(roll_xy, roll_yx, lag_xy, lag_yx, sname, tname, cfg, path):
    fig, axes = plt.subplots(2, 1, figsize=(11, 7), sharex=True)
    for ax, roll, title in (
        (axes[0], roll_xy, f"{sname} → {tname}   (lag {lag_xy})"),
        (axes[1], roll_yx, f"{tname} → {sname}   (lag {lag_yx})"),
    ):
        ax.plot(roll.index, roll["ete"], color="#1f4e79", lw=1.6,
                label="Effective TE (bias-corrected)")
        ax.plot(roll.index, roll["threshold"] - roll["surr_mean"],
                color="#c0392b", lw=1, ls="--",
                label=f"{int((1-cfg['alpha'])*100)}% significance threshold")
        sig = roll["p"] < cfg["alpha"]
        ax.fill_between(roll.index, 0, roll["ete"].clip(lower=0),
                        where=sig, color="#1f4e79", alpha=0.18,
                        label="significant windows")
        ax.axhline(0, color="k", lw=0.8)
        ax.set_title(title)
        ax.set_ylabel("ETE (bits)")
        ax.legend(fontsize=8, loc="upper left")
    axes[1].set_xlabel("window end date")
    fig.suptitle(f"{cfg['rolling_years']}-year rolling effective transfer entropy",
                 y=1.0)
    fig.tight_layout()
    fig.savefig(path, bbox_inches="tight")
    plt.close(fig)


