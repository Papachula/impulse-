# Orchestration
# ------------------------------------------------------------------------------
def run_analysis(df: pd.DataFrame, cfg) -> None:
    rng = np.random.default_rng(cfg["seed"])
    os.makedirs(cfg["output_dir"], exist_ok=True)
    sname, tname = cfg["source_col"], cfg["target_col"]

    print("=" * 78)
    print(f"TRANSFER ENTROPY ANALYSIS: {sname}  <->  {tname}")
    print("=" * 78)

    # 1) Transform ------------------------------------------------------------
    x = transform_series(df[sname], cfg["source_transform"], cfg["obs_per_year"])
    y = transform_series(df[tname], cfg["target_transform"], cfg["obs_per_year"])
    joint = pd.concat([x.rename("x"), y.rename("y")], axis=1).dropna()
    x, y = joint["x"], joint["y"]
    if cfg["standardize"]:
        x = (x - x.mean()) / x.std()
        y = (y - y.mean()) / y.std()
    print(f"\n[1] Data: {len(joint)} aligned observations, "
          f"{joint.index[0].date()} – {joint.index[-1].date()}")
    print(f"    {sname}: transform = {cfg['source_transform']}   "
          f"{tname}: transform = {cfg['target_transform']}")

    # 2) Stationarity ----------------------------------------------------------
    print("\n[2] Stationarity diagnostics (transformed series)")
    stat_rows = [stationarity_report(x, sname), stationarity_report(y, tname)]
    stat_df = pd.DataFrame(stat_rows)
    for r in stat_rows:
        print(f"    {r['series']:<12} ADF p={r['ADF p']:.4f}  "
              f"KPSS p={r['KPSS p']:.4f}  ->  {r['verdict']}")
    stat_df.to_csv(os.path.join(cfg["output_dir"], "stationarity.csv"), index=False)

    # 3) Lag scan (both directions) ---------------------------------------------
    print(f"\n[3] Full-sample lag scan (1..{cfg['max_lag']}), "
          f"{cfg['n_surrogates']} {cfg['surrogate_method']}-shuffle surrogates, "
          f"estimator = {cfg['estimator'].upper()}")
    xv, yv = x.values, y.values
    scan_xy = lag_scan(xv, yv, cfg, rng, f"{sname}->{tname}")
    scan_yx = lag_scan(yv, xv, cfg, rng, f"{tname}->{sname}")
    scan_xy.to_csv(os.path.join(cfg["output_dir"], "lag_scan_X_to_Y.csv"), index=False)
    scan_yx.to_csv(os.path.join(cfg["output_dir"], "lag_scan_Y_to_X.csv"), index=False)

    lag_xy, sig_xy = pick_optimal_lag(scan_xy, cfg["alpha"])
    lag_yx, sig_yx = pick_optimal_lag(scan_yx, cfg["alpha"])
    row_xy = scan_xy.set_index("lag").loc[lag_xy]
    row_yx = scan_yx.set_index("lag").loc[lag_yx]

    print(f"\n    Optimal lag {sname}->{tname}: {lag_xy} "
          f"(ETE={row_xy['ete']:.5f} bits, p={row_xy['p']:.4f}"
          f"{', SIGNIFICANT' if sig_xy else ', not significant'})")
    print(f"    Optimal lag {tname}->{sname}: {lag_yx} "
          f"(ETE={row_yx['ete']:.5f} bits, p={row_yx['p']:.4f}"
          f"{', SIGNIFICANT' if sig_yx else ', not significant'})")

    plot_lag_scan(scan_xy, scan_yx, sname, tname, cfg,
                  os.path.join(cfg["output_dir"], "lag_scan.png"))

    # 4) Rolling TE ---------------------------------------------------------------
    print(f"\n[4] {cfg['rolling_years']}-year rolling ETE "
          f"(window = {cfg['rolling_years'] * cfg['obs_per_year']} obs, "
          f"{cfg['rolling_surrogates']} surrogates/window)")
    roll_xy = rolling_te(x, y, lag_xy, cfg, rng, f"{sname}->{tname}")
    roll_yx = rolling_te(y, x, lag_yx, cfg, rng, f"{tname}->{sname}")
    roll_xy.to_csv(os.path.join(cfg["output_dir"], "rolling_te_X_to_Y.csv"))
    roll_yx.to_csv(os.path.join(cfg["output_dir"], "rolling_te_Y_to_X.csv"))
    plot_rolling(roll_xy, roll_yx, lag_xy, lag_yx, sname, tname, cfg,
                 os.path.join(cfg["output_dir"], "rolling_te.png"))

    # 5) Summary / interpretation ---------------------------------------------------
    frac_sig_xy = (roll_xy["p"] < cfg["alpha"]).mean()
    frac_sig_yx = (roll_yx["p"] < cfg["alpha"]).mean()
    lines = [
        "=" * 78,
        "SUMMARY -- predictive-information viability",
        "=" * 78,
        f"Sample: {joint.index[0].date()} to {joint.index[-1].date()} "
        f"({len(joint)} obs)",
        f"Estimator: {cfg['estimator'].upper()}  |  target history k="
        f"{cfg['k_history']}  |  alpha={cfg['alpha']}",
        "",
        f"{sname} -> {tname}: optimal lag {lag_xy}, "
        f"ETE = {row_xy['ete']:.5f} bits, p = {row_xy['p']:.4f} "
        f"({'significant' if sig_xy else 'NOT significant'}); "
        f"{frac_sig_xy:.0%} of rolling windows significant.",
        f"{tname} -> {sname}: optimal lag {lag_yx}, "
        f"ETE = {row_yx['ete']:.5f} bits, p = {row_yx['p']:.4f} "
        f"({'significant' if sig_yx else 'NOT significant'}); "
        f"{frac_sig_yx:.0%} of rolling windows significant.",
        "",
        "Interpretation guide:",
        "  * ETE > 0 with p < alpha  =>  the source's past carries information",
        "    about the target beyond the target's own history (predictive",
        "    viability in the information-theoretic sense).",
        "  * Compare directions: a large asymmetry indicates the dominant",
        "    direction of information flow.",
        "  * Rolling plot: information transfer in economic/financial data is",
        "    typically episodic -- viability should be judged by WHEN the flow",
        "    is significant (regimes), not only by the full-sample number.",
        "  * Caveats: TE is bivariate here -- a third variable driving both",
        "    series can induce apparent flow (consider conditioning candidates);",
        "    significance does not guarantee out-of-sample profitability.",
    ]
    summary = "\n".join(lines)
    print("\n" + summary)
    with open(os.path.join(cfg["output_dir"], "summary.txt"), "w") as f:
        f.write(summary + "\n")
    print(f"\nAll outputs written to: {os.path.abspath(cfg['output_dir'])}/")


# ------------------------------------------------------------------------------
# Self-test on synthetic data with a KNOWN causal structure
# ------------------------------------------------------------------------------
def make_synthetic(n=660, true_lag=3, coupling=1.0, seed=7) -> pd.DataFrame:
    """X: AR(1). Y: driven by X at `true_lag` plus own AR(1). Coupling turned
    OFF in the middle third so the rolling plot has a visible regime break."""
    rng = np.random.default_rng(seed)
    x = np.zeros(n)
    y = np.zeros(n)
    for t in range(1, n):
        x[t] = 0.4 * x[t - 1] + rng.standard_normal()
    regime = np.ones(n)
    regime[n // 3: 2 * n // 3] = 0.0        # coupling switched off mid-sample
    for t in range(true_lag, n):
        y[t] = (0.3 * y[t - 1]
                + coupling * regime[t] * x[t - true_lag]
                + rng.standard_normal())
    dates = pd.date_range("1971-01-31", periods=n, freq="ME")
    # exponentiate so the series look like positive "price/index levels"
    return pd.DataFrame({
        "DATE": dates,
        "WTI": np.exp(np.cumsum(x) * 0.02 + 3),
        "CPI": np.exp(np.cumsum(y) * 0.005 + 4),
    })


